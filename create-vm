#!/usr/bin/env bash
set -euo pipefail

# --- Setup Cleanup and Trap ---
TEMP_DIR=$(mktemp -d)
USER_DATA="${TEMP_DIR}/user-data"
META_DATA="${TEMP_DIR}/meta-data"
LOG_FILE="${TEMP_DIR}/error.log"

cleanup() {
    local exit_code=$?
    # Kill background sudo keep-alive
    if [[ -n "${SUDO_PID:-}" ]]; then
        kill "$SUDO_PID" 2>/dev/null || true
    fi
    # Remove temp files
    rm -rf "$TEMP_DIR"
    exit "$exit_code"
}
trap cleanup EXIT INT TERM

# --- Sudo Management ---
if ! sudo -n true 2>/dev/null; then
    echo "[+] Requesting sudo privileges"
    sudo -v </dev/tty
    # Keep-alive: update existing sudo time stamp until script has finished
    while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &
    SUDO_PID=$!
fi

# --- User Input ---
while true; do
    read -rp "VM Name: " VM_NAME </dev/tty
    if [[ -z "$VM_NAME" ]]; then
        echo "[-] Name cannot be empty"
        continue
    fi
    if sudo [ -f "/var/lib/libvirt/images/${VM_NAME}.qcow2" ]; then
        echo "[-] A VM with name '${VM_NAME}' already exists. Please choose a different name."
    else
        break
    fi
done

read -rp "Username [$USER]: " USERNAME </dev/tty
USERNAME=${USERNAME:-$USER}

read -rp "RAM (MB) [2048]: " VM_RAM_MB </dev/tty
VM_RAM_MB=${VM_RAM_MB:-2048}

read -rp "CPUs [2]: " VM_CPUS </dev/tty
VM_CPUS=${VM_CPUS:-2}

read -rp "Disk Size [20G]: " VM_DISK_SIZE </dev/tty
VM_DISK_SIZE=${VM_DISK_SIZE:-20G}

read -rp "Ports [none, e.g. 80,443]: " PORTS </dev/tty
PORTS=${PORTS:-none}

if [[ "$PORTS" != "none" ]]; then
    IFS=',' read -ra PORT_ARRAY <<< "$PORTS"
fi

# --- Configuration ---
CLOUD_IMG_URL="https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img"
BASE_IMG="/var/lib/libvirt/images/ubuntu-24.04-base.qcow2"
VM_DISK="/var/lib/libvirt/images/${VM_NAME}.qcow2"

# --- Step Execution Helper ---
run_step() {
    local msg="$1"
    shift
    echo "$msg"
    if ! sudo "$@" >"$LOG_FILE" 2>&1; then
        echo "[-] Failed at step: $msg"
        echo "--- Error Log ---"
        cat "$LOG_FILE"
        exit 1
    fi
}

echo
echo "[+] Detecting public key"
if [[ -f "$HOME/.ssh/id_ed25519.pub" ]]; then
    PUBKEY=$(<"$HOME/.ssh/id_ed25519.pub")
elif [[ -f "$HOME/.ssh/id_rsa.pub" ]]; then
    PUBKEY=$(<"$HOME/.ssh/id_rsa.pub")
else
    echo "[-] No SSH public key found in $HOME/.ssh/"
    exit 1
fi

run_step "[+] Installing packages" apt update
run_step "[+] Installing dependencies" apt install --no-install-recommends -y \
  qemu-system-x86 \
  qemu-utils \
  libvirt-daemon-system \
  libvirt-clients \
  virtinst \
  cloud-image-utils \
  wget \
  nftables

run_step "[+] Enabling libvirtd" systemctl enable --now libvirtd
run_step "[+] Updating group memberships" usermod -aG kvm,libvirt "$USER"
run_step "[+] Enabling IP forwarding" sysctl -w net.ipv4.ip_forward=1

if [ ! -f "$BASE_IMG" ]; then
  run_step "[+] Fetching base image" wget -q -O "$BASE_IMG" "$CLOUD_IMG_URL"
fi

echo "[+] Preparing cloud-init configuration"
read -r -d '' TEMPLATE <<'EOF' || true
#cloud-config

hostname: VM_NAME
fqdn: VM_NAME.local

users:
  - name: USERNAME
    groups: sudo
    shell: /bin/bash
    sudo: "ALL=(ALL) NOPASSWD:ALL"
    ssh_authorized_keys:
      - PUBKEY

packages:
  - avahi-daemon
  - libnss-mdns

write_files:
  - path: /etc/sudoers.d/90-nopasswd-sudo
    permissions: '0440'
    content: |
      %sudo ALL=(ALL) NOPASSWD:ALL
EOF

RESULT="${TEMPLATE//VM_NAME/$VM_NAME}"
RESULT="${RESULT//USERNAME/$USERNAME}"
RESULT="${RESULT//PUBKEY/$PUBKEY}"

printf '%s\n' "$RESULT" > "$USER_DATA"

cat > "$META_DATA" <<EOF
instance-id: ${VM_NAME}
local-hostname: ${VM_NAME}
EOF

run_step "[+] Creating VM disk" qemu-img create -f qcow2 -F qcow2 \
  -b "$BASE_IMG" \
  "$VM_DISK" \
  "$VM_DISK_SIZE"

run_step "[+] Installing VM" virt-install \
  --name "$VM_NAME" \
  --memory "$VM_RAM_MB" \
  --vcpus "$VM_CPUS" \
  --disk "$VM_DISK",device=disk,bus=virtio \
  --cloud-init user-data="$USER_DATA",meta-data="$META_DATA" \
  --os-variant ubuntu24.04 \
  --virt-type kvm \
  --graphics none \
  --network network=default,model=virtio \
  --import \
  --noautoconsole

echo "[+] Starting VM"
sudo virsh autostart "$VM_NAME" >/dev/null 2>&1
if ! sudo virsh domstate "$VM_NAME" | grep -q running; then
    sudo virsh start "$VM_NAME" >/dev/null 2>&1
fi

echo "[+] Waiting for VM IP"
VM_IP=""
for i in {1..60}; do
    VM_IP="$(
        sudo virsh domifaddr "$VM_NAME" --source lease 2>/dev/null |
        awk '/ipv4/ { sub("/.*", "", $4); print $4; exit }'
    )"

    [ -n "$VM_IP" ] && break

    sleep 2
done

if [ -z "$VM_IP" ]; then
    echo "[-] Could not detect VM IP."
    exit 1
fi

echo "[+] Detected VM IP: $VM_IP"

# Detect external interface to prevent DNAT from catching outbound traffic
EXT_IF=$(ip route | grep default | awk '{print $5; exit}')

if [[ "$PORTS" != "none" ]]; then
    run_step "[+] Initializing nftables table" nft add table ip hikaru
    run_step "[+] Initializing nftables chains" bash -c "
        nft 'add chain ip hikaru prerouting { type nat hook prerouting priority dstnat; }'
        nft 'add chain ip hikaru output { type nat hook output priority -100; }'
        # Priority -10 ensures we run BEFORE standard libvirt/system rules (priority 0)
        nft 'add chain ip hikaru postrouting { type nat hook postrouting priority -10; }'
        nft 'add chain ip hikaru forward { type filter hook forward priority -10; }'
    "

    run_step "[+] Clearing existing nftables rules for $VM_NAME" bash -c "
        for chain in prerouting output forward postrouting; do
            nft -a list chain ip hikaru \$chain 2>/dev/null | grep \"hikaru-vm-$VM_NAME\" | grep -oP 'handle \K\d+' | xargs -r -n1 nft delete rule ip hikaru \$chain handle 2>/dev/null || true
        done
    "

    for PORT in "${PORT_ARRAY[@]}"; do
        run_step "[+] Clearing nftables conflicts for port $PORT" bash -c "
            # Delete any existing rules for this port to keep it idempotent
            for chain in prerouting output forward postrouting; do
                nft -a list chain ip hikaru \$chain 2>/dev/null | grep \"dport $PORT\" | grep -oP 'handle \K\d+' | xargs -r -n1 nft delete rule ip hikaru \$chain handle 2>/dev/null || true
            done
        "
        
        # External access: Match any traffic destined for a local host IP on this port
        run_step "[+] Setting up external access for port $PORT" \
            nft add rule ip hikaru prerouting fib daddr type local tcp dport "$PORT" dnat to "$VM_IP:$PORT" comment "hikaru-vm-$VM_NAME"

        # Host access: When the host itself connects to its own IP or localhost
        HOST_IP=$(ip addr show "$EXT_IF" | grep -Po 'inet \K[\d.]+' | head -n1)
        run_step "[+] Setting up host access for port $PORT" \
            nft add rule ip hikaru output ip daddr "{ 127.0.0.1, $HOST_IP }" tcp dport "$PORT" dnat to "$VM_IP:$PORT" comment "hikaru-vm-$VM_NAME"

        # Forwarding: Ensure the packet is allowed through the filter
        run_step "[+] Setting up forwarding for port $PORT" \
            nft add rule ip hikaru forward ip daddr "$VM_IP" tcp dport "$PORT" accept comment "hikaru-vm-$VM_NAME"

        # Double NAT: Masquerade traffic to the VM so the return path and forwarding are guaranteed
        run_step "[+] Setting up masquerade for port $PORT" \
            nft add rule ip hikaru postrouting ip daddr "$VM_IP" tcp dport "$PORT" masquerade comment "hikaru-vm-$VM_NAME"
    done
fi

run_step "[+] Persisting nftables rules" bash -c "
    # Save only our specific table to a dedicated file
    nft list table ip hikaru > /etc/nftables.hikaru.conf

    # Ensure our dedicated file is included in the main config
    if ! grep -q 'include \"/etc/nftables.hikaru.conf\"' /etc/nftables.conf; then
        echo 'include \"/etc/nftables.hikaru.conf\"' >> /etc/nftables.conf
    fi
"
run_step "[+] Enabling and starting nftables" bash -c "systemctl enable nftables && systemctl start nftables"

run_step "[+] Updating host /etc/hosts" bash -c "
    sed -i '/[[:space:]]$VM_NAME\(\.local\)\?$/d' /etc/hosts
    echo '$VM_IP $VM_NAME $VM_NAME.local' >> /etc/hosts
"

run_step "[+] Enable automatic starting on boot" virsh autostart $VM_NAME

echo "[+] VM creation complete"

if ! groups "$USER" | grep -qE '\blibvirt\b'; then
    echo "[!] You will need to log out/in for libvirt group membership to apply."
fi
echo
echo "VM Name: $VM_NAME"
echo "VM IP: $VM_IP"
echo "mDNS: $VM_NAME.local"
echo
echo "Useful commands:"
echo "  virsh list --all"
echo "  virsh domifaddr $VM_NAME"
echo "  virsh console $VM_NAME"
echo "  virsh shutdown $VM_NAME"
echo "  virsh destroy $VM_NAME"
echo "  virsh undefine $VM_NAME --remove-all-storage"
